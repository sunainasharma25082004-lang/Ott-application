# ===========================================
# TALENT HUNT - Environment Variables Example
# ===========================================
# Copy this file to .env and fill in your real values
# Never commit .env to git!

# Server

PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/talenthunt?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_long_random_jwt_secret_here
JWT_EXPIRES_IN=7d

REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRES_IN=30d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Talent Hunt <no-reply@talenthunt.com>

# Twilio (optional for SMS OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Cloudinary
CLOUDINARY_CLOUD_NAME=nysjxidm
CLOUDINARY_API_KEY=475633273762885

CLOUDINARY_API_SECRET=gUdwtm8XPTsUcwF0In2Qf3nA6Xk

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800

# CORS
CORS_ORIGIN=http://localhost:8081,exp://*,http://localhost:3000

# Admin seed (used by node seed.js)
ADMIN_EMAIL=admin@talenthunt.com
ADMIN_PASSWORD=ChangeThisStrongPassword123!

# Security / Rate Limiting (optional overrides)
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=10

# Production
# NODE_ENV=production
# JWT_SECRET=use_a_very_long_random_string_in_production
# REFRESH_TOKEN_SECRET=another_long_random_string

# Stripe (optional)
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=

# API
API_BASE_URL=http://localhost:5000/api
